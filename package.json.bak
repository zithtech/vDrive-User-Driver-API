  "scripts": {
    "test": "jest --coverage",
    "test:auth": "jest __tests__ --testNamePattern=\"Auth\"",
    "dev": "ts-node-dev --respawn --transpile-only --ignore-watch logs,app.log src/server.ts",
    "migrate": "node-pg-migrate",
    "build": "tsc",
    "start": "tsc && node dist/server.js",
    "setup": "npm install && npm run build",
    "migrate:up": "npm run migrate",
    "migrate:up:N": "npx ts-node ./node_modules/.bin/node-pg-migrate up $N --migrations-table custom_migrations --schema public --verbose --single-transaction",
    "migrate:down": "npx ts-node ./node_modules/.bin/node-pg-migrate down --migrations-table custom_migrations --schema public --verbose --single-transaction",
    "migrate:down:N": "npx ts-node ./node_modules/.bin/node-pg-migrate down $N --migrations-table custom_migrations --schema public --verbose --single-transaction",
    "migrate:redo": "npx ts-node ./node_modules/.bin/node-pg-migrate redo --migrations-table custom_migrations --schema public --verbose --single-transaction",
    "migrate:redo:N": "npx ts-node ./node_modules/.bin/node-pg-migrate redo $N --migrations-table custom_migrations --schema public --verbose --single-transaction",
    "migrate:create": "npx ts-node ./node_modules/.bin/node-pg-migrate create",
    "migrate:create:ts": "npx ts-node ./node_modules/.bin/node-pg-migrate create -j ts",
    "migrate:status": "npx ts-node ./node_modules/.bin/node-pg-migrate up --fake --migrations-table custom_migrations --schema public --verbose",
    "migrate:reset": "npx ts-node ./node_modules/.bin/node-pg-migrate down --migrations-table custom_migrations --schema public --verbose --single-transaction",
    "migrate:reset:all": "npx ts-node ./node_modules/.bin/node-pg-migrate down $(npx ts-node ./node_modules/.bin/node-pg-migrate --list | grep -c '^up') --migrations-table custom_migrations --schema public --verbose --single-transaction"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.{ts,js}",
      "!src/**/*.d.ts",
      "!src/server.ts",
      "!src/**/*.test.ts"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/src/__tests__/setup.ts"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ithyaz-zithmi/vDrive-User-Driver-API.git"
  },
  "keywords": [],
