# Copy to .env and fill in real values. DO NOT commit the real .env.
# In Dokploy these go in the app's Environment tab (not in git).

# --- Server ---
NODE_ENV=development
PORT=3000
API_VERSION=v1
SERVICE_NAME=vdrive-user-driver-api
PROD_URL=
TZ=Asia/Kolkata

# --- Database (Postgres) ---
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_NAME_TEST=
PGSSLMODE=
PGCHANNELBINDING=

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Auth / JWT ---
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- OTP ---
OTP_EXPIRY_TIME=
OTP_REQUEST_LIMIT=
OTP_REQUEST_WINDOW=
OTP_BLOCK_DURATION=
MAX_ATTEMPTS=

# --- Internal / cross-service comms ---
ADMIN_API_URL=
ADMIN_BACKEND_URL=
ADMIN_INTERNAL_SOCKET_URL=
INTERNAL_SERVICE_API_KEY=
INTERNAL_SERVICE_SECRET=
AWS_SERVICE_URL=

# --- AWS / S3 ---
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_ENDPOINT=
S3_BUCKET_NAME=

# --- Email / SMTP ---
EMAIL_SERVICE=
EMAIL_USER=
EMAIL_PASS=
SMTP_USER=

# --- Payments (Razorpay) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Ride/matching config ---
DEFAULT_SEARCH_RADIUS=
AVG_SPEED_METERS_PER_MIN=
REFERRAL_DOWNLOAD_URL=

# --- Firebase (push notifications) ---
# Two ways to supply the service account; use ONE:
#  1) FIREBASE_SERVICE_ACCOUNT_PATH: path INSIDE the container to the JSON key.
#     In Dokploy add a File Mount with this path and paste the key JSON.
#  2) FIREBASE_SERVICE_ACCOUNT: the entire key JSON as a single-line value.
FIREBASE_SERVICE_ACCOUNT_PATH=/app/firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT=
